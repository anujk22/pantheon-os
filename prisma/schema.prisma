// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "sqlite"
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  systemPrompt  String?
  responseStyle String?   @default("considerate")
  memoryMode    String?   @default("summaries")
  themeMode     String?   @default("system")
  llmProvider   String?   @default("lmstudio")
  llmBaseUrl    String?
  llmApiKey     String?
  llmModel      String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Case {
  id          String   @id @default(cuid())
  title       String
  description String?
  status      String   @default("active")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  tasks       Task[]
  artifacts   Artifact[]
  chatSessions ChatSession[]
  inboxItems  InboxItem[]
  memories    Memory[]
}

model Task {
  id          String   @id @default(cuid())
  title       String
  description String?
  status      String   @default("todo") // todo, in_progress, done
  dueDate     DateTime?
  caseId      String?
  case        Case?    @relation(fields: [caseId], references: [id])
  sourceInboxItemId String?
  sourceInboxItem   InboxItem? @relation(fields: [sourceInboxItemId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Event {
  id          String   @id @default(cuid())
  title       String
  description String?
  date        DateTime
  source      String   @default("manual") // manual, google_calendar
  externalId  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ChatSession {
  id           String   @id @default(cuid())
  title        String
  folder       String?
  caseId       String?
  case         Case?    @relation(fields: [caseId], references: [id])
  isSummarized Boolean  @default(false)
  summary      String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  messages     ChatMessage[]
}

model ChatMessage {
  id        String   @id @default(cuid())
  role      String   // user, assistant, system
  content   String
  vectorId  String?  // Reference to VectorDB entry
  sessionId String
  session   ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model Artifact {
  id          String   @id @default(cuid())
  title       String
  type        String   // text, code, data, web
  content     String
  caseId      String?
  case        Case?    @relation(fields: [caseId], references: [id])
  sourceInboxItemId String?
  sourceInboxItem   InboxItem? @relation(fields: [sourceInboxItemId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Memory {
  id          String   @id @default(cuid())
  content     String
  memoryType  String   @default("fact")
  sourceType  String   @default("manual")
  sourceRef   String?
  confidence  Float?
  caseId      String?
  case        Case?    @relation(fields: [caseId], references: [id])
  sourceInboxItemId String?
  sourceInboxItem   InboxItem? @relation(fields: [sourceInboxItemId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model InboxItem {
  id          String   @id @default(cuid())
  title       String
  body        String
  sourceType  String   @default("manual") // manual, chat, calendar, canvas, file, codex, import, system
  sourceRef   String?
  status      String   @default("untriaged") // untriaged, triaged, archived
  suggestedDestination String @default("unknown") // task, case, artifact, memory, archive, unknown
  confidence  Float?
  caseId      String?
  case        Case?    @relation(fields: [caseId], references: [id])
  triagedAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  tasks       Task[]
  artifacts   Artifact[]
  memories    Memory[]
}

model MorningBriefing {
  id        String   @id @default(cuid())
  date      DateTime @unique
  content   String
  createdAt DateTime @default(now())
}

model AgentAction {
  id          String    @id @default(cuid())
  title       String
  description String?
  kind        String    // create_task, save_artifact, save_memory, create_case, archive_inbox, external_draft
  status      String    @default("pending") // pending, approved, rejected, executed, failed
  sourceType  String    @default("manual") // inbox, chat, cadence, manual, integration
  sourceRef   String?
  payloadJson String
  resultJson  String?
  error       String?
  createdBy   String    @default("athena")
  approvedAt  DateTime?
  executedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}
